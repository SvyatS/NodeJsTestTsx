  },
  "homepage": "https://github.com/SvyatS/NodeJsTestTsx#readme",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "migrate-mongo": "^14.0.7",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.4.2",
